# ── 服务端口 ──
PORT=3000

# ── JWT 签名密钥（生产环境务必换成足够长的随机串）──
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# ── 数据库文件位置（SQLite；生产可换成托管 Postgres，见 README）──
DB_PATH=./data/aixcellent.db

# ── 启动时自动创建的默认管理员账号 ──
ADMIN_EMAIL=admin@aixcellent.health
ADMIN_PASSWORD=replace-with-strong-admin-password

# ── 前端站点地址（用于 CORS 白名单，逗号分隔；* 表示允许全部，生产请收敛）──
CORS_ORIGIN=*
